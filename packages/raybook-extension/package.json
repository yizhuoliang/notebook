{
  "name": "@jupyter-notebook/raybook-extension",
  "version": "7.7.0-alpha.0",
  "description": "RayBook distributed cell executor for Jupyter Notebook",
  "homepage": "https://github.com/yizhuoliang/RayBook",
  "repository": {
    "type": "git",
    "url": "https://github.com/yizhuoliang/notebook.git"
  },
  "license": "BSD-3-Clause",
  "author": "Project Jupyter and RayBook contributors",
  "sideEffects": [
    "style/**/*.css",
    "style/index.js"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "directories": {
    "lib": "lib/"
  },
  "files": [
    "lib/*.d.ts",
    "lib/*.js.map",
    "lib/*.js",
    "schema/*.json",
    "style/**/*.css",
    "style/index.js"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:prod": "tsc -b",
    "clean": "rimraf lib && rimraf tsconfig.tsbuildinfo",
    "watch": "tsc -b --watch"
  },
  "dependencies": {
    "@jupyterlab/application": "~4.7.0-alpha.0",
    "@jupyterlab/apputils": "~4.8.0-alpha.0",
    "@jupyterlab/cells": "~4.7.0-alpha.0",
    "@jupyterlab/coreutils": "~6.7.0-alpha.0",
    "@jupyterlab/nbformat": "~4.7.0-alpha.0",
    "@jupyterlab/notebook": "~4.7.0-alpha.0",
    "@jupyterlab/services": "~7.7.0-alpha.0",
    "@jupyterlab/translation": "~4.7.0-alpha.0",
    "@lumino/widgets": "^2.7.2"
  },
  "devDependencies": {
    "rimraf": "^3.0.2",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "schemaDir": "schema"
  },
  "styleModule": "style/index.js"
}
